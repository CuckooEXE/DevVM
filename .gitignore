# Populated by `./bootstrap.sh --mode prepare`. Large, machine-specific.
# `vmconfig.lock` in the repo root IS committed (pinned versions).
cache/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/

# Virtual envs
.venv/
venv/
env/

# Secrets / local config
.env
.env.*
!.env.example

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS cruft
.DS_Store
Thumbs.db
Desktop.ini

# Scratch / backup / logs
*.log
*.bak
*.orig
*.rej
/tmp-*

# NeovimOffline bundle artifacts — large (~350 MB staged). Regenerated by
# `NeovimOffline/stage.sh` on a connected machine. The scripts + config are
# tracked; the downloaded binaries and plugin trees are not.
NeovimOffline/bin/*.tar.gz
NeovimOffline/bin/*.tar.xz
NeovimOffline/jdk/*.tar.gz
NeovimOffline/share/nvim/lazy/
NeovimOffline/share/nvim/mason/
NeovimOffline/share/nvim/site/
NeovimOffline/.stage/
NeovimOffline/.downloads/
