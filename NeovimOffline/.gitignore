# Artifacts (bin/, jdk/, share/nvim/{lazy,mason,site}, .stage/, .downloads/)
# now live under <repo>/cache/neovim_offline/ and are ignored by the top
# level .gitignore's `cache/` rule. This file only handles editor/OS cruft
# that might sneak into the source tree.

# Editor / tooling
.claude/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
